public class LifecycleTracker {
    static class TaskRunner implements Runnable {
        @Override
        public void run() {
            try {
                Thread.sleep(2000); 
            } catch (InterruptedException e) {
                System.out.println("Thread interrupted!");
            }
        }
    }
    public static void main(String[] args) 
    throws InterruptedException
    {
Thread thread = new Thread(new TaskRunner());
System.out.println("State 1 (After creation): " + thread.getState());
    thread.start();
System.out.println("State 2 (After start()): " + thread.getState());
    Thread.sleep(100);
System.out.println("State 3(During sleep):"+thread.getState());
    thread.join();
System.out.println("State 4 (After join()): " + thread.getState());
    }
}
