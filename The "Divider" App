import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("--- Division Recovery Experiment ---");
        try {
            System.out.print("Enter numerator (a): ");
            int a = sc.nextInt();
            System.out.print("Enter divisor (b): ");
            int b = sc.nextInt();
            int result = a / b;
            System.out.println("Result: " + result);
        } catch (ArithmeticException e) {
            // Program jumps here if division by zero occurs
            System.out.println("\n[RECOVERED] Observation: A fatal error occurred (Division by zero).");
            System.out.println("Message: Please try again with a non-zero number.");
        } finally {
            System.out.println("Calculation Attempt Finished.");
        }
        System.out.println("\n--- Program Status: Still Running ---");
        System.out.println("Because we caught the exception, the code reached this final line.");
        sc.close();
    }
}
