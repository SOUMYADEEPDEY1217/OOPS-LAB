import java.util.Scanner;
class Staff {
    protected double salary;
    private String bankAccount;
    public Staff(double salary, String bankAccount) {
        this.salary = salary;
        this.bankAccount = bankAccount;
    }
}
class Intern extends Staff {
    public Intern(double salary, String bankAccount) {
        super(salary, bankAccount);
    }
    public void tryAccess() {
        System.out.println("--- Access Results ---");
        System.out.println("Salary (Protected): Visible -> " + salary);
        System.out.println("Bank Account (Private): Hidden (Would cause error if accessed directly)");
    }
}
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter Staff Salary: ");
        double s = sc.nextDouble();
        sc.nextLine(); 
        System.out.print("Enter Bank Account Number: ");
        String b = sc.nextLine();
        Intern studentIntern = new Intern(s, b);
        studentIntern.tryAccess();
        sc.close();
    }
}
