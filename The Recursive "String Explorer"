import java.util.Scanner;
interface StringOperations {
    String reverseString(String str);
    int countVowels(String str);
}
class StringProcessor implements StringOperations {
    @Override
    public String reverseString(String str) {
        if (str == null || str.length() <= 1) {
            return str;
        }
        return str.charAt(str.length() - 1) + reverseString(str.substring(0, str.length() - 1));
    }
    @Override
    public int countVowels(String str) {
        if (str == null || str.isEmpty()) {
            return 0;
        }
        int count = isVowel(str.charAt(0)) ? 1 : 0;
        return count + countVowels(str.substring(1));
    }
    private boolean isVowel(char ch) {
        ch = Character.toLowerCase(ch);
        return ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u';
    }
}
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        StringProcessor processor = new StringProcessor();
        System.out.print("Enter a string: ");
        String input = sc.nextLine();
        String reversed = processor.reverseString(input);
        int vowelCount = processor.countVowels(input);
        System.out.println("Reversed: " + reversed);
        System.out.println("Vowel Count: " + vowelCount);
        sc.close();
    }
}
